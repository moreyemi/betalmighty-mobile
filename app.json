{
  "expo": {
    "name": "BetAlmighty",
    "slug": "betalmighty-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A4A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.betalmighty.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#1B2A4A"
      },
      "package": "com.betalmighty.app"
    },
    "plugins": [
      ["expo-camera", {"cameraPermission": "Allow BetAlmighty to access your camera"}],
      ["expo-notifications", {"icon": "./src/assets/notification-icon.png", "color": "#F47920"}]
    ]
  }
}
